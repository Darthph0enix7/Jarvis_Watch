# ─────────────────────────────────────────────────────────────────────────────
# Jarvis Voice Assistant — Environment Variables
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Koyeb: set these in the dashboard (Secrets) or with the CLI:
#   koyeb secrets create <name> --value "<value>"
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Shared secret used for two purposes:
#   1. Client authentication on every WebSocket and REST endpoint
#   2. Decrypting the bundled Firebase service account (.enc file)
# Must match the token used when running encrypt_creds.py.
JARVIS_AUTH_TOKEN=your_secret_token_here

# Cartesia API key — used for both STT (Whisper) and TTS (Sonic)
# https://cartesia.ai
CARTESIA_API_KEY=sk_car_...

# Cerebras API key — required when LLM_PROVIDER=cerebras (the default)
# https://cerebras.ai
CEREBRAS_API_KEY=csk-...


# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Google Gemini API key — only needed when LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...

# LLM provider to use: "cerebras" (default) or "gemini"
# LLM_PROVIDER=cerebras

# HTTP port the server listens on.
# Koyeb sets this automatically; you rarely need to change it.
# PORT=8000

# Path to the Firebase service account JSON file (plain or .enc).
# Defaults to the bundled jarvis-app-43084-...-c836619551.json(.enc).
# FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json

# How often (in minutes) the server polls device GPS locations.
# LOCATION_INTERVAL=30
